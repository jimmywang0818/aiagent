# Omnichat
OMNICHAT_API_TOKEN=your_omnichat_api_token_here
OMNICHAT_TEAM_ID=your_team_id_here

# Google Vertex AI (使用 GCP Application Default Credentials，不需要 API Key)
# Project ID 在 GCP Console 左上角
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# 建議用 us-central1（模型支援最完整），或 asia-southeast1（新加坡）
VERTEX_LOCATION=us-central1

# Cyberbiz
CYBERBIZ_API_TOKEN=your_cyberbiz_api_token_here

# Brand (ID from brands table, default 7 = 達摩)
BRAND_ID=7

# Server
PORT=3000
WEBHOOK_PATH=/omnichat-webhook

# Admin panel
ADMIN_PASSWORD=change_this_password
SESSION_SECRET=change_this_secret

# Shopee Review API (用於 n8n 呼叫)
SHOPEE_API_KEY=change_this_to_random_string

# Internal Ask API (用於 n8n 或其他外部呼叫 /api/ask)
INTERNAL_API_KEY=change_this_to_random_string

# Google Chat Webhook (needs_human 時通知)
GOOGLE_CHAT_WEBHOOK=https://chat.googleapis.com/v1/spaces/...
